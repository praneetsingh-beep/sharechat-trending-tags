# Optional — system runs without keys using free sources (Google Trends RSS, Reddit, Wikipedia)
# Add these for higher quality:

# NewsAPI.org — India headlines (free tier 100 req/day)
NEWSAPI_KEY=

# SerpAPI — Google Trends India real-time (free tier 100 req/mo)
SERPAPI_KEY=

# Anthropic — Hindi translation + AI summaries (Claude Haiku is cheap, ~$1 for the demo)
ANTHROPIC_API_KEY=

# Used by /api/refresh to allow Vercel cron only
CRON_SECRET=replace-with-random-string
